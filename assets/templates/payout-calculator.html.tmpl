<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Payout Calculator</title>
    <link rel="stylesheet" href="/style/{{ .Theme }}/css">
</head>
<body>
    {{ template "user-bar" . }}
    <div class="container">
        <div class="admin-bar">
            <a href="/">&lt; Back to Home</a>
        </div>

        <h1>Payout Calculator</h1>
        <style>
            #calcForm .form-row {
                display: flex;
                align-items: center;
                margin-bottom: 0.5em;
            }
            #calcForm .form-row label {
                display: inline;
                margin: 0;
                width: 12em;
                text-align: right;
                padding-right: 1em;
                flex-shrink: 0;
            }
            #calcForm .form-row input,
            #calcForm .form-row select {
                width: auto;
            }
            @media (max-width: 600px) {
                #calcForm .form-row {
                    flex-wrap: wrap;
                }
                #calcForm .form-row label {
                    width: auto;
                    text-align: left;
                    padding-right: 0;
                    flex-shrink: 1;
                }
                #calcForm .form-row input,
                #calcForm .form-row select {
                    width: 100%;
                }
            }
        </style>
        <form id="calcForm">
            <div class="form-row">
                <label for="PaytableID">Payout Table</label>
                <select id="PaytableID" name="PaytableID" required>
                    {{- range $_, $pt := .Paytables }}
                    <option value="{{ $pt.ID }}"
                      {{- if eq $pt.ID $.SelectedPaytableID }} selected{{ end -}}
                      >{{ $pt.Name }}</option>
                    {{- end }}
                </select>
            </div>

            <div class="form-row">
                <label for="NumPlayers">Number of Players</label>
                <input type="number" placeholder="100" pattern="[0-9,]*" id="NumPlayers" name="NumPlayers" min="1"{{ if .NumPlayers }} value="{{ .NumPlayers }}"{{ end }} required>
            </div>

            <div class="form-row">
                <label for="PrizePool">Prize Pool ($)</label>
                <input type="number" placeholder="10000" pattern="[0-9,]*" id="PrizePool" name="PrizePool" min="1"{{ if .PrizePool }} value="{{ .PrizePool }}"{{ end }} required>
            </div>

            <div class="form-row">
                <label for="Labels">Labels</label>
                <select id="Labels">
                    <option value="ordinal" selected>1st, 2nd, 3rd, ...</option>
                    <option value="numeric">1, 2, 3, ...</option>
                </select>
            </div>
        </form>

        <div id="results"></div>
        <div id="error"></div>
    </div>

    <script>
        function recalculate() {
            const paytableID = parseInt(document.getElementById('PaytableID').value, 10);
            const numPlayers = parseInt(document.getElementById('NumPlayers').value, 10);
            const prizePool = parseInt(document.getElementById('PrizePool').value, 10);

            const resultsDiv = document.getElementById('results');
            const errorDiv = document.getElementById('error');

            if (isNaN(paytableID) || !numPlayers || numPlayers < 1 || !prizePool || prizePool < 1) {
                resultsDiv.innerHTML = '';
                errorDiv.innerHTML = '';
                return;
            }

            const ordinalSuffix = document.getElementById('Labels').value === 'ordinal';

            fetch('/api/payout-calculator', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    paytableId: paytableID,
                    numPlayers: numPlayers,
                    prizePool: prizePool,
                    ordinalSuffix: ordinalSuffix
                })
            })
            .then(function(resp) {
                if (!resp.ok) {
                    return resp.text().then(function(t) { throw new Error(t); });
                }
                return resp.json();
            })
            .then(function(data) {
                errorDiv.innerHTML = '';
                if (!data || data.length === 0) {
                    resultsDiv.innerHTML = '';
                    return;
                }
                var html = '<hr> <table class="data-table"><thead><tr><th>Place</th><th>Prize</th></tr></thead><tbody>';
                for (var i = 0; i < data.length; i++) {
                    html += '<tr><td>' + data[i].place + '</td><td>$' + data[i].prize.toLocaleString('en-US') + '</td></tr>';
                }
                html += '</tbody></table>';
                resultsDiv.innerHTML = html;
            })
            .catch(function(err) {
                resultsDiv.innerHTML = '';
                errorDiv.innerHTML = '<div class="flash-boo">' + err.message + '</div>';
            });
        }

        document.getElementById('PaytableID').addEventListener('change', recalculate);
        document.getElementById('NumPlayers').addEventListener('input', recalculate);
        document.getElementById('PrizePool').addEventListener('input', recalculate);
        document.getElementById('Labels').addEventListener('change', recalculate);
    </script>
</body>
</html>

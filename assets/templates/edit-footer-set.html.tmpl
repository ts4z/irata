<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>{{ if .IsNew }}Create{{ else }}Edit{{ end }} Footer Plug Set</title>
    <link rel="stylesheet" href="/style/{{ .Theme }}/css">
    <script>
      function addPlug() {
        const plugsDiv = document.getElementById('plugs');
        const idx = plugsDiv.children.length;
        const row = document.createElement('div');
        row.className = 'plug-row';
        row.innerHTML = `<textarea name="Plug${idx}" required></textarea> <button type="button" class="delete-btn" onclick="this.parentNode.remove()">❌</button>`;
        plugsDiv.appendChild(row);
      }
    </script>
</head>
<body>
    {{ template "navbar" . }}
    <div class="container">

        <h1>{{ if .IsNew }}Create{{ else }}Edit{{ end }} Footer Plug Set</h1>
        <form method="POST">
            <div class="form-group">
                <label for="Name">Set Name</label>
                <input type="text" id="Name" name="Name" value="{{ .FooterSet.Name }}" required>
            </div>

            <div class="form-group">
                <label>Footer Plugs</label>
                <div id="plugs">
                    {{ range $i, $plug := .FooterSet.TextPlugs }}
                    <div class="plug-row">
                        <textarea name="Plug{{ $i }}" required>{{ $plug }}</textarea>
                        <button type="button" class="delete-btn" onclick="this.parentNode.remove()">❌</button>
                    </div>
                    {{ end }}
                </div>
                <button type="button" id="add-plug-btn" onclick="addPlug()">Add Plug</button>
            </div>

            <div class="actions">
                <button type="submit">{{ if .IsNew }}Create{{ else }}Save{{ end }}</button>
                <button type="button" data-cancel-href="/manage/footer-set/">Cancel</button>
            </div>
            
            {{ if .Flash }}<div class="flash">{{ .Flash }}</div>{{ end }}
        </form>
    </div>
<script>
  window.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('button[data-cancel-href]').forEach(function(btn) {
      var form = btn.closest('form');
      var snapshot = new URLSearchParams(new FormData(form)).toString();
      btn.addEventListener('click', function() {
        var current = new URLSearchParams(new FormData(form)).toString();
        if (current === snapshot || confirm('You have unsaved changes. Discard?')) {
          window.location.href = btn.dataset.cancelHref;
        }
      });
    });
  });
</script>
</body>
</html>
